generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["platform", "system"]
}

// ----------------------------------------------------------------------
// ENUMS
// ----------------------------------------------------------------------

enum ConnectorType {
  GOOGLE_DRIVE
  GOOGLE_CALENDAR
  GOOGLE_TASKS
  DROPBOX
  ONEDRIVE
  BOX
  NOTION
  CONFLUENCE

  @@schema("platform")
}

enum ConnectorStatus {
  ACTIVE
  EXPIRED
  REVOKED
  ERROR

  @@schema("platform")
}

enum DocumentStatus {
  PROCESSING
  PROCESSED
  ERROR
  ARCHIVED

  @@schema("platform")
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  JOINED
  EXPIRED

  @@schema("platform")
}

enum TicketType {
  BUG
  REQUEST
  ENQUIRY

  @@schema("platform")
}

enum TicketStatus {
  NEW
  IN_PROGRESS
  RESOLVED
  CLOSED

  @@schema("platform")
}

enum OrgRole {
  org_admin
  org_member

  @@schema("platform")
}

enum ProjectRole {
  proj_admin
  proj_member
  proj_ext_collaborator
  proj_viewer

  @@schema("platform")
}

enum MembershipType {
  internal
  external

  @@schema("platform")
}

// ----------------------------------------------------------------------
// PLATFORM SCHEMA (V2)
// ----------------------------------------------------------------------

model Connector {
  id                String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  type              ConnectorType   @default(GOOGLE_DRIVE)
  userId            String          @db.Uuid
  externalAccountId String
  name              String?
  avatarUrl         String?
  accessToken       String
  refreshToken      String?
  tokenExpiresAt    DateTime?
  status            ConnectorStatus @default(ACTIVE)
  lastSyncAt        DateTime?
  settings          Json            @default("{}")

  organizations Organization[]

  @@unique([type, userId])
  @@map("connectors")
  @@schema("platform")
}

model Organization {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name               String
  slug               String   @unique
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  
  settings           Json     @default("{}")
  allowDomainAccess  Boolean  @default(false)
  allowedEmailDomain String?
  stripeCustomerId   String?
  subscriptionStatus String?  @default("none")
  brandingSubtext    String?
  logoUrl            String?
  themeColorHex      String?
  connectorId        String?  @db.Uuid
  orgFolderId        String?
  sandboxOnly        Boolean  @default(false)

  connector       Connector? @relation(fields: [connectorId], references: [id])
  clients         Client[]
  projects        Project[]
  members         OrgMember[]
  invitations     OrgInvitation[]
  searchIndex     ProjectDocumentSearchIndex[]

  @@map("organizations")
  @@schema("platform")
}

model Client {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String   @db.Uuid
  name           String
  slug           String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  industry       String?
  sector         String?
  status         String?  @default("ACTIVE")
  settings       Json     @default("{}")
  sandboxOnly    Boolean  @default(false)
  driveFolderId  String?

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  projects     Project[]
  members      ClientMember[]

  @@unique([organizationId, slug])
  @@map("clients")
  @@schema("platform")
}

model Project {
  id                    String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId        String   @db.Uuid
  clientId              String   @db.Uuid
  name                  String
  slug                  String
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  description           String?
  connectorRootFolderId String?
  settings              Json     @default("{}")
  isClosed              Boolean  @default(false)
  isDeleted             Boolean  @default(false)
  sandboxOnly           Boolean  @default(false)

  organization          Organization                 @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client                Client                       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  files                 ProjectFile[]
  members               ProjectMember[]
  invitations           ProjectInvitation[]
  grants                FilePersonaGrant[]
  searchIndex           ProjectDocumentSearchIndex[]
  sharings              ProjectDocumentSharing[]
  sharingUsers          ProjectDocumentSharingUser[]

  @@unique([clientId, slug])
  @@map("projects")
  @@schema("platform")
}

model Persona {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug        String  @unique
  displayName String
  description String?

  clientMembers      ClientMember[]
  projectInvitations ProjectInvitation[]
  orgInvitations     OrgInvitation[]

  @@map("personas")
  @@schema("platform")
}

model OrgMember {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String         @db.Uuid
  organizationId  String         @db.Uuid
  role            OrgRole
  membershipType  MembershipType @default(internal)
  isDefault       Boolean        @default(false)
  settings        Json           @default("{}")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@map("org_members")
  @@schema("platform")
}

model ClientMember {
  id        String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String @db.Uuid
  clientId  String @db.Uuid
  personaId String @db.Uuid
  isDefault Boolean @default(false)
  settings  Json @default("{}")

  client    Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  persona   Persona @relation(fields: [personaId], references: [id], onDelete: Cascade)

  @@unique([userId, clientId, personaId])
  @@map("client_members")
  @@schema("platform")
}

model ProjectMember {
  id        String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String      @db.Uuid
  projectId String      @db.Uuid
  role      ProjectRole
  settings  Json        @default("{}")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@map("project_members")
  @@schema("platform")
}

model ProjectFile {
  id             String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId          String  @db.Uuid
  projectId      String  @db.Uuid
  externalFileId String
  name           String
  type           String // 'folder' | 'document'
  parentId       String? @db.Uuid

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_files")
  @@schema("platform")
}

model FilePersonaGrant {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  fileId          String   @db.Uuid
  projectId       String   @db.Uuid
  personaSlug     String
  grantedByUserId String   @db.Uuid
  grantedAt       DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("file_persona_grants")
  @@schema("platform")
}

model ProjectInvitation {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  projectId       String           @db.Uuid
  email           String
  personaId       String           @db.Uuid
  status          InvitationStatus @default(PENDING)
  token           String           @unique
  expireAt        DateTime?
  acceptedAt      DateTime?
  joinedAt        DateTime?
  
  project         Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  persona         Persona          @relation(fields: [personaId], references: [id], onDelete: Cascade)

  @@unique([projectId, email])
  @@map("project_invitations")
  @@schema("platform")
}

model OrgInvitation {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  organizationId  String           @db.Uuid
  email           String
  personaId       String           @db.Uuid
  status          InvitationStatus @default(PENDING)
  token           String           @unique
  expireAt        DateTime?
  acceptedAt      DateTime?
  joinedAt        DateTime?
  
  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  persona         Persona          @relation(fields: [personaId], references: [id], onDelete: Cascade)

  @@unique([organizationId, email])
  @@map("org_invitations")
  @@schema("platform")
}

model ProjectDocumentSearchIndex {
  id                      String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId          String                  @db.Uuid
  clientId                String?                 @db.Uuid
  projectId               String?                 @db.Uuid
  connectorId             String?                 @db.Uuid
  externalId              String
  parentId                String?
  fileName                String
  isFolder                Boolean                 @default(false)
  mimeType                String?
  fileSize                BigInt?
  status                  DocumentStatus          @default(PROCESSED)
  content                 String?
  embedding               Unsupported("vector")?
  metadata                Json                    @default("{}")
  sandboxOnly             Boolean                 @default(false)
  createdAt               DateTime                @default(now()) @db.Timestamptz(6)
  updatedAt               DateTime                @default(now()) @updatedAt @db.Timestamptz(6)
  
  projectDocumentSharings ProjectDocumentSharing[]
  organization            Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project                 Project?                @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([organizationId, externalId], map: "pdsi_org_external_idx_v2")
  @@index([organizationId, clientId, projectId], map: "pdsi_org_client_project_idx_v2")
  @@index([embedding], map: "pdsi_embedding_idx_v2")
  @@map("project_document_search_index")
  @@schema("platform")
}

model ProjectDocumentSharing {
  id             String                       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt      DateTime                     @default(now())
  updatedAt      DateTime                     @updatedAt
  projectId      String                       @db.Uuid
  organizationId String                       @db.Uuid
  searchIndexId  String?                      @db.Uuid
  externalId     String?                      // Google Drive File/Folder ID
  settings       Json                         @default("{}")
  slug           String?                      @unique
  createdBy      String?                      @db.Uuid
  updatedBy      String?                      @db.Uuid
  
  users         ProjectDocumentSharingUser[]
  project       Project                      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  searchIndex   ProjectDocumentSearchIndex?  @relation(fields: [searchIndexId], references: [id], onDelete: Cascade)

  @@unique([projectId, organizationId, externalId])
  @@map("project_document_sharing")
  @@schema("platform")
}

model ProjectDocumentSharingUser {
  id                 String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  sharingId          String                 @db.Uuid
  projectId          String                 @db.Uuid
  userId             String                 @db.Uuid
  email              String
  googlePermissionId String?
  
  sharing            ProjectDocumentSharing @relation(fields: [sharingId], references: [id], onDelete: Cascade)
  project            Project                @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  @@unique([sharingId, userId])
  @@map("project_document_sharing_users")
  @@schema("platform")
}

// ----------------------------------------------------------------------
// SYSTEM SCHEMA
// ----------------------------------------------------------------------

model SystemAdmin {
  id     String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId String @db.Uuid
  role   String

  @@map("system_admins")
  @@schema("system")
}

model ContactSubmission {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  ipAddress      String?  @map("ip_address")
  email          String?
  plan           String?
  role           String?
  teamSize       String?  @map("team_size")
  painPoint      String?  @map("pain_point")
  featureRequest String?  @map("feature_request")
  comments       String?

  @@map("contact_submissions")
  @@schema("system")
}

model Waitlist {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  email         String
  plan          String   @default("Pro")
  companyName   String?  @map("company_name")
  companySize   String?  @map("company_size")
  role          String?
  comments      String?
  ipAddress     String?  @map("ip_address")
  referralCode  String?  @unique @default(dbgenerated("\"substring\"((gen_random_uuid())::text, 1, 8)")) @map("referral_code")
  referredBy    String?  @map("referred_by")
  referralCount Int      @default(0) @map("referral_count")
  positionBoost Int      @default(0) @map("position_boost")

  @@index([createdAt], map: "idx_waitlist_created_at")
  @@index([email], map: "idx_waitlist_email")
  @@index([plan], map: "idx_waitlist_plan")
  @@index([referralCode], map: "idx_waitlist_referral_code")
  @@index([referredBy], map: "idx_waitlist_referred_by")
  @@map("waitlist")
  @@schema("system")
}

model CustomerRequest {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  type           TicketType
  status         TicketStatus @default(NEW)
  description    String
  errorDetails   Json?
  metadata       Json?
  organizationId String?  @db.Uuid
  clientId       String?  @db.Uuid
  projectId      String?  @db.Uuid
  userId         String?  @db.Uuid
  userEmail      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([status], map: "idx_customer_requests_status")
  @@index([userId], map: "idx_customer_requests_user")
  @@map("customer_requests")
  @@schema("platform")
}

model PlatformConfig {
  id    String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key   String @unique
  value Json

  @@map("platform_config")
  @@schema("platform")
}
