generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["public", "portal", "admin", "rbac"]
}

model Organization {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  name      String
  slug      String   @unique // URL-friendly identifier
  settings  Json     @default("{}")

  // Allow domain access: users with this email domain can join org without invite (org member only)
  allowDomainAccess   Boolean  @default(false)
  allowedEmailDomain  String?  // e.g. "acme.com" (lowercase)

  // Billing Fields
  stripeCustomerId   String?
  subscriptionStatus String?   @default("none") // active, trialing, past_due, canceled, unpaid, none

  members    OrganizationMember[]
  connectors Connector[]
  documents  Document[]
  clients    Client[]
  projects   Project[]
  organizationPersonas OrganizationPersona[]

  @@schema("portal")
  @@map("organizations")
}

model Client {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  organizationId String   @db.Uuid
  name           String
  slug           String
  
  // Optional business fields
  industry       String?
  sector         String?

  status         String   @default("ACTIVE")
  settings       Json     @default("{}")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  projects     Project[]
  members      ClientMember[]
  clientPersonas ClientPersona[]

  @@schema("portal")
  @@unique([organizationId, slug])
  @@index([organizationId])
  @@map("clients")
}

model Project {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  organizationId String   @db.Uuid
  clientId      String   @db.Uuid // Required: Project must belong to a Client
  name          String
  slug          String
  description   String?
  connectorRootFolderId String?  // Root folder ID in connected storage (Drive, Dropbox, etc.)
  settings      Json     @default("{}")
  isClosed      Boolean  @default(false) // View-only for current members
  isDeleted     Boolean  @default(false) // Soft delete; hidden from everyone

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client       Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  documents    Document[]
  members      ProjectMember[]
  invitations  ProjectInvitation[]
  projectPersonas ProjectPersona[]

  @@schema("portal")
  @@unique([clientId, slug])
  @@index([organizationId])
  @@index([clientId])
  @@map("projects")
}

// ============================================================================
// RBAC Schema (Global Definitions)
// ============================================================================

model RbacRole {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug        String   @unique
  displayName String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  personas RbacPersona[]

  @@schema("rbac")
  @@map("roles")
}

model RbacPermissionScope {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  grants RbacGrant[]

  @@schema("rbac")
  @@map("permission_scopes")
}

model RbacPrivilege {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  grants RbacGrant[]

  @@schema("rbac")
  @@map("privileges")
}

model RbacPersona {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug        String   @unique
  displayName String
  description String?
  roleId      String   @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  role   RbacRole      @relation(fields: [roleId], references: [id])
  grants RbacGrant[]

  // Portal schema links (org-specific customizations)
  organizationPersonas OrganizationPersona[]
  clientPersonas       ClientPersona[]
  projectPersonas      ProjectPersona[]

  @@schema("rbac")
  @@map("personas")
}

model RbacGrant {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  personaId   String   @db.Uuid
  scopeId     String   @db.Uuid
  privilegeId String   @db.Uuid
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  persona  RbacPersona       @relation(fields: [personaId], references: [id], onDelete: Cascade)
  scope    RbacPermissionScope @relation(fields: [scopeId], references: [id], onDelete: Cascade)
  privilege RbacPrivilege     @relation(fields: [privilegeId], references: [id], onDelete: Cascade)

  @@schema("rbac")
  @@unique([personaId, scopeId, privilegeId])
  @@map("grants")
}

// ============================================================================
// Portal Schema (Membership & Entity-Specific Personas)
// ============================================================================

model OrganizationMember {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  organizationId      String   @db.Uuid
  userId              String   @db.Uuid // Supabase user ID is UUID
  organizationPersonaId String? @db.Uuid
  isDefault           Boolean  @default(false) // Primary org for this user

  organization        Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationPersona OrganizationPersona? @relation(fields: [organizationPersonaId], references: [id])

  @@schema("portal")
  @@unique([organizationId, userId])
  @@index([userId])
  @@index([userId, isDefault])
  @@map("organization_members")
}

model OrganizationPersona {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String   @db.Uuid
  rbacPersonaId  String   @db.Uuid
  displayName    String
  description    String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  rbacPersona RbacPersona    @relation(fields: [rbacPersonaId], references: [id])
  members     OrganizationMember[]

  @@schema("portal")
  @@unique([organizationId, rbacPersonaId])
  @@map("organization_personas")
}

model ClientPersona {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId      String   @db.Uuid
  rbacPersonaId String   @db.Uuid
  displayName   String
  description   String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  client      Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  rbacPersona RbacPersona   @relation(fields: [rbacPersonaId], references: [id])
  members     ClientMember[]

  @@schema("portal")
  @@unique([clientId, rbacPersonaId])
  @@index([clientId])
  @@map("client_personas")
}

model ClientMember {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId     String   @db.Uuid
  userId       String   @db.Uuid
  clientPersonaId String? @db.Uuid
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  client       Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientPersona ClientPersona? @relation(fields: [clientPersonaId], references: [id])

  @@schema("portal")
  @@unique([clientId, userId])
  @@index([userId])
  @@map("client_members")
}

model Connector {
  id                 String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  organizationId     String          @db.Uuid
  type               ConnectorType   @default(GOOGLE_DRIVE)
  externalAccountId  String          // Provider account id (e.g. Google sub, Dropbox account id)
  email              String
  name               String?
  avatarUrl          String?
  accessToken        String          // Stores AES-256-GCM encrypted: "v{n}$base64(iv+ciphertext+tag)"
  refreshToken       String?         // Stores AES-256-GCM encrypted: "v{n}$base64(iv+ciphertext+tag)"
  tokenExpiresAt     DateTime?
  status             ConnectorStatus @default(ACTIVE)
  lastSyncAt         DateTime?
  settings           Json            @default("{}")
  organization       Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  documents          Document[]
  linkedFiles        LinkedFile[]

  @@schema("portal")
  @@unique([organizationId, type, externalAccountId])
  @@map("connectors")
}

model Document {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  organizationId String         @db.Uuid
  connectorId    String?        @db.Uuid
  externalId     String
  title          String
  mimeType       String
  fileSize       BigInt?
  webViewLink    String?
  content        String?
  summary        String?
  tags           String[]       @default([])
  metadata       Json           @default("{}")
  status         DocumentStatus @default(PROCESSING)
  lastModifiedAt DateTime?
  connector      Connector?     @relation(fields: [connectorId], references: [id])
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  projectId      String?        @db.Uuid
  project        Project?       @relation(fields: [projectId], references: [id])

  @@schema("portal")
  @@unique([organizationId, externalId])
  @@map("documents")
}

model ProjectMember {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  projectId String   @db.Uuid
  userId    String   @db.Uuid // Supabase user ID

  // Link to Persona
  personaId String?  @db.Uuid
  settings  Json     @default("{}")

  project Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  persona ProjectPersona? @relation(fields: [personaId], references: [id])

  @@schema("portal")
  @@unique([projectId, userId])
  @@index([userId])
  @@map("project_members")
}

model ProjectPersona {
  id             String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId      String     @db.Uuid
  rbacPersonaId  String     @db.Uuid
  displayName    String
  description    String?
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  project   Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  rbacPersona RbacPersona @relation(fields: [rbacPersonaId], references: [id])
  members     ProjectMember[]
  invitations ProjectInvitation[]

  @@schema("portal")
  @@unique([projectId, rbacPersonaId])
  @@index([projectId])
  @@map("project_personas")
}

model ProjectInvitation {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  projectId      String           @db.Uuid
  email          String
  personaId      String           @db.Uuid
  status         InvitationStatus @default(PENDING)
  token          String           @unique
  expireAt       DateTime?
  acceptedAt     DateTime?
  joinedAt       DateTime?

  project Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  persona ProjectPersona @relation(fields: [personaId], references: [id])

  @@schema("portal")
  @@unique([projectId, email])
  @@map("project_invitations")
}

model LinkedFile {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  connectorId    String   @db.Uuid
  fileId         String
  metadata       Json     @default("{}")
  isGrantRevoked Boolean  @default(false) @map("is_grant_revoked")
  linkedAt       DateTime @default(now())

  connector   Connector @relation(fields: [connectorId], references: [id], onDelete: Cascade)

  @@schema("portal")
  @@unique([connectorId, fileId])
  @@map("linked_files")
}

model ContactSubmission {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at")
  ipAddress      String?  @map("ip_address")
  email          String?
  plan           String?
  role           String?
  teamSize       String?  @map("team_size")
  painPoint      String?  @map("pain_point")
  featureRequest String?  @map("feature_request")
  comments       String?

  @@schema("admin")
  @@map("contact_submissions")
}

model Waitlist {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at")
  email         String
  plan          String   @default("Pro")
  companyName   String?  @map("company_name")
  companySize   String?  @map("company_size")
  role          String?
  comments      String?
  ipAddress     String?  @map("ip_address")
  
  // Referral fields
  referralCode  String   @unique @default(dbgenerated("substring(gen_random_uuid()::text, 1, 8)")) @map("referral_code")
  referredBy    String?  @map("referred_by") // referralCode of the person who referred them
  referralCount Int      @default(0) @map("referral_count") // How many people they've referred
  positionBoost Int      @default(0) @map("position_boost") // Total positions gained from referrals

  @@schema("admin")
  @@index([email])
  @@index([plan])
  @@index([createdAt])
  @@index([referralCode])
  @@index([referredBy])
  @@map("waitlist")
}

enum ConnectorType {
  GOOGLE_DRIVE
  GOOGLE_CALENDAR
  GOOGLE_TASKS
  DROPBOX
  ONEDRIVE
  BOX
  NOTION
  CONFLUENCE

  @@schema("portal")
}

enum ConnectorStatus {
  ACTIVE
  EXPIRED
  REVOKED
  ERROR

  @@schema("portal")
}

enum DocumentStatus {
  PROCESSING
  PROCESSED
  ERROR
  ARCHIVED

  @@schema("portal")
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  JOINED
  EXPIRED

  @@schema("portal")
}

model CustomerRequest {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  type        TicketType
  status      TicketStatus @default(NEW)
  
  description String       
  errorDetails Json?       
  metadata     Json?       

  // Context
  organizationId String? @db.Uuid
  clientId       String? @db.Uuid
  projectId      String? @db.Uuid

  userId      String?      @db.Uuid
  userEmail   String?
  
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@schema("portal")
  @@index([userId])
  @@index([status])
  @@map("customer_requests")
}

enum TicketType {
  BUG
  REQUEST
  ENQUIRY

  @@schema("portal")
}

enum TicketStatus {
  NEW
  IN_PROGRESS
  RESOLVED
  CLOSED

  @@schema("portal")
}
