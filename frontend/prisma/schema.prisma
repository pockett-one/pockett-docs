generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["platform", "system"]
}

// ----------------------------------------------------------------------
// ENUMS
// ----------------------------------------------------------------------

enum ConnectorType {
  GOOGLE_DRIVE
  GOOGLE_CALENDAR
  GOOGLE_TASKS
  DROPBOX
  ONEDRIVE
  BOX
  NOTION
  CONFLUENCE

  @@schema("platform")
}

enum ConnectorStatus {
  ACTIVE
  EXPIRED
  REVOKED
  ERROR

  @@schema("platform")
}

/** Where the Google Drive workspace root folder lives (persisted; backfilled from Drive API when null). */
enum WorkspaceRootLocation {
  MY_DRIVE
  SHARED_DRIVE

  @@schema("platform")
}

enum DocumentStatus {
  PROCESSING
  PROCESSED
  ERROR
  ARCHIVED

  @@schema("platform")
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  JOINED
  EXPIRED

  @@schema("platform")
}

enum TicketType {
  BUG
  REQUEST
  ENQUIRY

  @@schema("platform")
}

enum TicketStatus {
  NEW
  IN_PROGRESS
  RESOLVED
  CLOSED

  @@schema("platform")
}

enum FirmRole {
  firm_admin
  firm_member

  @@schema("platform")
}

enum EngagementRole {
  eng_admin
  eng_member
  eng_ext_collaborator
  eng_viewer

  @@schema("platform")
}

enum MembershipType {
  internal
  external

  @@schema("platform")
}

enum ClientStatus {
  PROSPECT
  ACTIVE
  ON_HOLD
  PAST

  @@schema("platform")
}

enum EngagementStatus {
  PLANNED
  ACTIVE
  COMPLETED
  PAUSED

  @@schema("platform")
}

enum NotificationPriority {
  INFO
  WARNING
  CRITICAL

  @@schema("platform")
}

// ----------------------------------------------------------------------
// PLATFORM SCHEMA (V2)
// ----------------------------------------------------------------------

model Connector {
  id                String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  createdBy         String?         @db.Uuid
  updatedBy         String?         @db.Uuid
  type              ConnectorType   @default(GOOGLE_DRIVE)
  userId            String          @db.Uuid
  externalAccountId String
  name              String?
  avatarUrl         String?
  accessToken       String
  refreshToken      String?
  tokenExpiresAt    DateTime?
  status            ConnectorStatus @default(ACTIVE)
  lastSyncAt        DateTime?
  settings          Json            @default("{}")
  /** Set when workspace root is known; null until backfilled from Drive or an update. */
  workspaceRootLocation        WorkspaceRootLocation?
  /** Google shared drive id (Drive API `driveId`) when location is SHARED_DRIVE. */
  workspaceRootSharedDriveId   String?
  /** Cached shared drive display name for UI. */
  workspaceRootSharedDriveName String?
  /** Firm owner (new model). Legacy firm.connectorId flow may still be present during migration. */
  firmId            String?         @db.Uuid

  firms Firm[] @relation("LegacyFirmConnector")
  firm  Firm?  @relation("FirmConnectors", fields: [firmId], references: [id], onDelete: SetNull)

  @@unique([type, userId])
  @@index([firmId])
  @@map("connectors")
  @@schema("platform")
}

model Firm {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name               String
  slug               String    @unique
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  createdBy          String?   @db.Uuid
  updatedBy          String?   @db.Uuid
  deletedBy          String?   @db.Uuid
  deletedAt          DateTime? @db.Timestamptz(6)

  settings           Json     @default("{}")
  allowDomainAccess  Boolean  @default(false)
  allowedEmailDomain String?
  stripeCustomerId   String?
  subscriptionStatus String?  @default("none")
  subscriptionProvider String?
  subscriptionPlan     String?
  pricingModel         String?
  subscriptionCurrentPeriodEnd DateTime? @db.Timestamptz(6)
  polarCustomerId      String?
  polarSubscriptionId  String?
  polarOrderId         String?
  /**
   * Optional backdoor: extra firm workspaces on a single paid subscription.
   * Satellite firms set this to the anchor firm id; the anchor holds polarSubscriptionId / subscriptionStatus.
   * Anchor may set billingGroupFirmCap to the max total firms in the group (anchor + satellites); null = 1.
   */
  billingSharesSubscriptionFromFirmId String? @db.Uuid
  billingGroupFirmCap                 Int?
  /**
   * Effective max concurrent ACTIVE engagements for workspaces under this billing anchor (grandfathering + exceptions).
   * Null = derive from subscription plan at runtime until webhook/free-plan provisioning sets it.
   */
  billingActiveEngagementCap          Int?
  /** When true, Polar webhooks must not overwrite billing*Cap fields (manual exceptions). */
  billingCapsLocked                   Boolean  @default(false)

  /** Optional umbrella anchor: satellites point to an anchor firm id (one-level hierarchy). */
  anchorFirmId        String?  @db.Uuid

  brandingSubtext    String?
  logoUrl            String?
  themeColorHex      String?
  connectorId        String?  @db.Uuid
  firmFolderId       String?
  sandboxOnly        Boolean  @default(false) @map("isAnchor")

  connector         Connector?        @relation("LegacyFirmConnector", fields: [connectorId], references: [id])
  connectors        Connector[]       @relation("FirmConnectors")
  anchorFirm        Firm?             @relation("FirmAnchorHierarchy", fields: [anchorFirmId], references: [id], onDelete: SetNull)
  anchoredFirms     Firm[]            @relation("FirmAnchorHierarchy")
  billingSubscriptionAnchor Firm?     @relation("FirmBillingShare", fields: [billingSharesSubscriptionFromFirmId], references: [id], onDelete: SetNull)
  satelliteFirms            Firm[]    @relation("FirmBillingShare")
  subscriptions             Subscription[]
  clients           Client[]
  engagements       Engagement[]
  members           FirmMember[]
  invitations       FirmInvitation[]
  engagementDocuments EngagementDocument[]
  docCommentMessages DocCommentMessage[]
  platformAuditEvents PlatformAuditEvent[]

  @@index([billingSharesSubscriptionFromFirmId])
  @@index([anchorFirmId])
  @@map("firms")
  @@schema("platform")
}

model Subscription {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  createdBy          String?   @db.Uuid
  updatedBy          String?   @db.Uuid
  deletedAt          DateTime? @db.Timestamptz(6)
  deactivatedAt      DateTime? @db.Timestamptz(6)
  firmId             String    @db.Uuid
  provider           String?   @default("polar")
  status             String    @default("active")
  plan               String?
  polarCustomerId    String?
  polarSubscriptionId String?
  polarOrderId       String?
  active             Boolean   @default(true)
  settings           Json      @default("{}")

  firm               Firm      @relation(fields: [firmId], references: [id], onDelete: Cascade)

  @@index([firmId, active])
  @@index([polarSubscriptionId])
  @@map("subscriptions")
  @@schema("platform")
}

model Client {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  firmId         String    @db.Uuid
  name           String
  slug           String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  createdBy      String?   @db.Uuid
  updatedBy      String?   @db.Uuid
  deletedBy      String?   @db.Uuid
  deletedAt      DateTime? @db.Timestamptz(6)

  industry       String?
  sector         String?
  status         ClientStatus @default(ACTIVE)
  /** Firm member (user id) who owns this client relationship. */
  ownerId        String?  @db.Uuid
  website        String?
  description    String?  @db.Text
  tags           Json     @default("[]")
  settings       Json     @default("{}")
  sandboxOnly    Boolean  @default(false)
  driveFolderId  String?

  firm                Firm                @relation(fields: [firmId], references: [id], onDelete: Cascade)
  engagements         Engagement[]
  members             ClientMember[]
  invitations         ClientInvitation[]
  engagementDocuments EngagementDocument[]
  docCommentMessages  DocCommentMessage[]
  platformAuditEvents PlatformAuditEvent[]
  contacts            ClientContact[]

  @@unique([firmId, slug])
  @@map("clients")
  @@schema("platform")
}

model ClientContact {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  createdBy      String?   @db.Uuid
  updatedBy      String?   @db.Uuid
  firmId         String    @db.Uuid
  clientId       String    @db.Uuid
  engagementId   String?   @db.Uuid
  name           String
  email          String?
  phone          String?
  title          String?
  notes          String?
  tags           Json      @default("[]")

  client         Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  engagement     Engagement? @relation(fields: [engagementId], references: [id], onDelete: SetNull)

  @@unique([clientId, email])
  @@index([firmId, clientId])
  @@map("client_contacts")
  @@schema("platform")
}

model Engagement {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  firmId                String    @db.Uuid
  clientId              String    @db.Uuid
  name                  String
  slug                  String
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  createdBy             String?   @db.Uuid
  updatedBy             String?   @db.Uuid
  deletedBy             String?   @db.Uuid
  deletedAt             DateTime? @db.Timestamptz(6)

  description           String?
  connectorRootFolderId String?
  kickoffDate           DateTime? @db.Timestamptz(6)
  dueDate               DateTime? @db.Timestamptz(6)
  status                EngagementStatus @default(ACTIVE)
  contractType          String?
  rateOrValue           Decimal? @db.Decimal(15, 2)
  tags                  Json     @default("[]")
  settings              Json     @default("{}")
  isDeleted             Boolean  @default(false)
  sandboxOnly           Boolean  @default(false)

  firm                  Firm                         @relation(fields: [firmId], references: [id], onDelete: Cascade)
  client                Client                       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  members               EngagementMember[]
  invitations           EngagementInvitation[]
  grants                FilePersonaGrant[]
  documents             EngagementDocument[]
  sharingUsers          EngagementDocumentSharingUser[]
  docCommentMessages    DocCommentMessage[]
  platformAuditEvents   PlatformAuditEvent[]
  notifications         Notification[]
  canvases              EngagementCanvas[]
  contacts              ClientContact[]

  @@unique([clientId, slug])
  @@map("engagements")
  @@schema("platform")
}

model Persona {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug        String  @unique
  displayName String
  description String?

  clientMembers         ClientMember[]
  engagementInvitations EngagementInvitation[]
  firmInvitations       FirmInvitation[]
  clientInvitations     ClientInvitation[]

  @@map("personas")
  @@schema("platform")
}

model FirmMember {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String         @db.Uuid
  firmId          String         @db.Uuid
  role            FirmRole
  membershipType  MembershipType @default(internal)
  isDefault       Boolean        @default(false)
  settings        Json           @default("{}")
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  createdBy       String?        @db.Uuid
  updatedBy       String?        @db.Uuid

  firm Firm @relation(fields: [firmId], references: [id], onDelete: Cascade)

  @@unique([userId, firmId])
  @@map("firm_members")
  @@schema("platform")
}

model ClientMember {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @db.Uuid
  clientId  String   @db.Uuid
  personaId String   @db.Uuid
  isDefault Boolean  @default(false)
  settings  Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?  @db.Uuid
  updatedBy String?  @db.Uuid

  client    Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  persona   Persona @relation(fields: [personaId], references: [id], onDelete: Cascade)

  @@unique([userId, clientId, personaId])
  @@map("client_members")
  @@schema("platform")
}

model EngagementMember {
  id           String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String          @db.Uuid
  engagementId String          @db.Uuid
  role         EngagementRole
  settings     Json            @default("{}")
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  createdBy    String?         @db.Uuid
  updatedBy    String?         @db.Uuid

  engagement Engagement @relation(fields: [engagementId], references: [id], onDelete: Cascade)

  @@unique([userId, engagementId])
  @@map("engagement_members")
  @@schema("platform")
}

model FilePersonaGrant {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  fileId          String   @db.Uuid
  engagementId    String   @db.Uuid
  personaSlug     String
  grantedByUserId String   @db.Uuid
  grantedAt       DateTime @default(now())

  engagement Engagement @relation(fields: [engagementId], references: [id], onDelete: Cascade)

  @@map("file_persona_grants")
  @@schema("platform")
}

model EngagementInvitation {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  createdBy       String?          @db.Uuid
  updatedBy       String?          @db.Uuid
  engagementId    String           @db.Uuid
  email           String
  personaId       String           @db.Uuid
  status          InvitationStatus @default(PENDING)
  token           String           @unique
  expireAt        DateTime?
  acceptedAt      DateTime?
  joinedAt        DateTime?
  
  engagement      Engagement       @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  persona         Persona          @relation(fields: [personaId], references: [id], onDelete: Cascade)

  @@unique([engagementId, email])
  @@map("engagement_invitations")
  @@schema("platform")
}

model FirmInvitation {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  createdBy       String?          @db.Uuid
  updatedBy       String?          @db.Uuid
  firmId          String           @db.Uuid
  email           String
  personaId       String           @db.Uuid
  status          InvitationStatus @default(PENDING)
  token           String           @unique
  expireAt        DateTime?
  acceptedAt      DateTime?
  joinedAt        DateTime?
  
  firm            Firm             @relation(fields: [firmId], references: [id], onDelete: Cascade)
  persona         Persona          @relation(fields: [personaId], references: [id], onDelete: Cascade)

  @@unique([firmId, email])
  @@map("firm_invitations")
  @@schema("platform")
}

model ClientInvitation {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  createdBy       String?          @db.Uuid
  updatedBy       String?          @db.Uuid
  clientId        String           @db.Uuid
  email           String
  personaId       String           @db.Uuid
  status          InvitationStatus @default(PENDING)
  token           String           @unique
  expireAt        DateTime?
  acceptedAt      DateTime?
  joinedAt        DateTime?

  client          Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  persona         Persona          @relation(fields: [personaId], references: [id], onDelete: Cascade)

  @@unique([clientId, email])
  @@map("client_invitations")
  @@schema("platform")
}

model EngagementDocument {
  id             String                       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt      DateTime                     @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime                     @default(now()) @updatedAt @db.Timestamptz(6)
  firmId         String                       @db.Uuid
  clientId       String?                      @db.Uuid
  engagementId  String                       @db.Uuid
  connectorId    String?                      @db.Uuid
  externalId     String
  parentId       String?
  fileName       String
  isFolder       Boolean                     @default(false)
  mimeType       String?
  fileSize       BigInt?
  status         DocumentStatus              @default(PROCESSED)
  content        String?
  embedding      Unsupported("vector")?
  metadata       Json                        @default("{}")
  sandboxOnly    Boolean                     @default(false)
  dueDate        DateTime?                   @db.Timestamptz(6)
  settings       Json                        @default("{}")
  slug           String?                     @unique
  createdBy      String?                     @db.Uuid
  updatedBy      String?                     @db.Uuid

  sharingUsers   EngagementDocumentSharingUser[]
  firm           Firm                         @relation(fields: [firmId], references: [id], onDelete: Cascade)
  client         Client?                     @relation(fields: [clientId], references: [id], onDelete: SetNull)
  engagement     Engagement                 @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  docCommentMessages DocCommentMessage[]
  platformAuditEvents PlatformAuditEvent[]
  notifications       Notification[]

  @@unique([engagementId, firmId, externalId])
  @@index([firmId, clientId, engagementId])
  @@index([embedding])
  @@map("engagement_documents")
  @@schema("platform")
}

model Notification {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt      DateTime @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @db.Timestamptz(6)
  createdBy      String?  @db.Uuid
  updatedBy      String?  @db.Uuid
  firmId         String   @db.Uuid
  clientId       String?  @db.Uuid
  engagementId   String?  @db.Uuid
  documentId     String?  @db.Uuid

  userId         String   @db.Uuid
  type           String
  priority       NotificationPriority @default(INFO)
  title          String
  body           String?
  ctaUrl         String?
  metadata       Json     @default("{}")
  channels       Json     @default("{}")
  dedupeKey      String?

  readAt         DateTime? @db.Timestamptz(6)
  dismissedAt    DateTime? @db.Timestamptz(6)
  deliveredAt    DateTime? @db.Timestamptz(6)
  emailSentAt    DateTime? @db.Timestamptz(6)

  engagement    Engagement?         @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  document       EngagementDocument? @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([firmId, clientId, userId])
  @@index([clientId, engagementId, documentId])
  @@index([userId, readAt])
  @@index([userId, dismissedAt])
  @@map("platform_notifications")
  @@schema("platform")
}

model UserPersonalization {
  userId     String   @id @db.Uuid
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  createdBy  String?  @db.Uuid
  updatedBy  String?  @db.Uuid
  bookmarks  Json     @default("[]")
  notes      String?  @db.Text

  @@map("user_personalizations")
  @@schema("platform")
}

model EngagementCanvas {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  createdBy       String?  @db.Uuid
  updatedBy       String?  @db.Uuid

  firmId          String   @db.Uuid
  clientId        String   @db.Uuid
  engagementId    String   @db.Uuid

  content         String   @default("") @db.Text
  allowExternal   Boolean  @default(false)

  engagement      Engagement  @relation(fields: [engagementId], references: [id], onDelete: Cascade)

  @@unique([engagementId])
  @@index([firmId, engagementId])
  @@map("engagement_canvases")
  @@schema("platform")
}

model EngagementDocumentSharingUser {
  id                 String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  createdBy          String?         @db.Uuid
  updatedBy          String?         @db.Uuid
  projectDocumentId  String          @db.Uuid
  engagementId       String          @db.Uuid
  userId             String          @db.Uuid
  email              String
  googlePermissionId String?

  document           EngagementDocument @relation(fields: [projectDocumentId], references: [id], onDelete: Cascade)
  engagement         Engagement         @relation(fields: [engagementId], references: [id], onDelete: Cascade)

  @@unique([projectDocumentId, userId])
  @@map("engagement_document_sharing_users")
  @@schema("platform")
}

model DocCommentMessage {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  createdBy         String?  @db.Uuid
  updatedBy         String?  @db.Uuid

  firmId            String   @db.Uuid
  clientId          String   @db.Uuid
  engagementId      String   @db.Uuid
  projectDocumentId String   @db.Uuid

  authorUserId      String?  @db.Uuid

  content           String
  reactions         Json     @default("{}")

  firm              Firm           @relation(fields: [firmId], references: [id], onDelete: Cascade)
  client            Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  engagement        Engagement    @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  projectDocument   EngagementDocument @relation(fields: [projectDocumentId], references: [id], onDelete: Cascade)

  @@index([engagementId, projectDocumentId, createdAt])
  @@map("doc_comment_messages")
  @@schema("platform")
}

enum PlatformAuditScope {
  PROJECT

  @@schema("platform")
}

enum PlatformAuditEventType {
  // Project lifecycle
  PROJECT_CREATED
  PROJECT_UPDATED
  PROJECT_CLOSED
  PROJECT_REOPENED
  PROJECT_SOFT_DELETED
  // Membership
  PROJECT_MEMBER_ADDED
  PROJECT_MEMBER_REMOVED
  PROJECT_MEMBER_ROLE_CHANGED
  // Document lifecycle within project
  PROJECT_DOCUMENT_ADDED
  PROJECT_DOCUMENT_REMOVED
  PROJECT_DOCUMENT_RENAMED
  // Document sharing & workflow (legacy aliases kept for compatibility)
  FILE_UPLOADED
  STATUS_CHANGE
  SHARED_EXT
  PROJECT_LOCKED
  DOCUMENT_ACTIVITY_STATUS_CHANGED
  DOCUMENT_SHARED_INTERNAL
  DOCUMENT_SHARED_EXTERNAL
  DOCUMENT_SHARE_FINALIZED
  DOCUMENT_SHARE_REGRANTED
  // Indexing
  PROJECT_INDEX_REQUESTED
  DOCUMENT_INDEX_REQUESTED
  DOCUMENT_INDEX_COMPLETED
  // Config
  PROJECT_CONNECTOR_FOLDER_ATTACHED
  PROJECT_SETTINGS_CHANGED
  DOCUMENT_ACCESS_LOG_ENTRY

  @@schema("platform")
}

model PlatformAuditEvent {
  id                String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt         DateTime               @default(now())

  firmId            String                 @db.Uuid
  clientId          String?                @db.Uuid
  engagementId     String?                @db.Uuid
  projectDocumentId String?                @db.Uuid

  scope             PlatformAuditScope
  eventType         PlatformAuditEventType
  eventAt           DateTime               @default(now())

  actorUserId       String?                @db.Uuid

  metadata          Json                   @default("{}")

  firm              Firm                   @relation(fields: [firmId], references: [id], onDelete: Cascade)
  client            Client?                @relation(fields: [clientId], references: [id], onDelete: SetNull)
  engagement       Engagement?           @relation(fields: [engagementId], references: [id], onDelete: SetNull)
  projectDocument   EngagementDocument? @relation(fields: [projectDocumentId], references: [id], onDelete: SetNull)

  @@index([engagementId, eventAt])
  @@index([engagementId, projectDocumentId, eventAt])
  @@map("platform_audit_events")
  @@schema("platform")
}

// ----------------------------------------------------------------------
// SYSTEM SCHEMA
// ----------------------------------------------------------------------

model SystemAdmin {
  id     String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId String @db.Uuid
  role   String

  @@map("system_admins")
  @@schema("system")
}

model ContactSubmission {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  ipAddress   String?  @map("ip_address")
  email       String?
  role        String?
  teamSize    String?  @map("team_size")
  inquiryType String?  @map("inquiry_type")
  message     String?

  @@map("contact_submissions")
  @@schema("system")
}

model Waitlist {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  email         String
  plan          String   @default("Pro")
  companyName   String?  @map("company_name")
  companySize   String?  @map("company_size")
  role          String?
  comments      String?
  ipAddress     String?  @map("ip_address")
  referralCode  String?  @unique @default(dbgenerated("\"substring\"((gen_random_uuid())::text, 1, 8)")) @map("referral_code")
  referredBy    String?  @map("referred_by")
  referralCount Int      @default(0) @map("referral_count")
  positionBoost Int      @default(0) @map("position_boost")

  @@index([createdAt], map: "idx_waitlist_created_at")
  @@index([email], map: "idx_waitlist_email")
  @@index([plan], map: "idx_waitlist_plan")
  @@index([referralCode], map: "idx_waitlist_referral_code")
  @@index([referredBy], map: "idx_waitlist_referred_by")
  @@map("waitlist")
  @@schema("system")
}

model CustomerRequest {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  type           TicketType
  status         TicketStatus @default(NEW)
  description    String
  errorDetails   Json?
  metadata       Json?
  firmId         String?  @db.Uuid
  clientId       String?  @db.Uuid
  engagementId   String?  @db.Uuid
  userId         String?  @db.Uuid
  userEmail      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([status], map: "idx_customer_requests_status")
  @@index([userId], map: "idx_customer_requests_user")
  @@map("customer_requests")
  @@schema("platform")
}

model PlatformConfig {
  id    String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key   String @unique
  value Json

  @@map("platform_config")
  @@schema("platform")
}
